GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=asia-northeast1
GEMINI_MODEL=gemini-2.5-flash
# When true, AI endpoints skip the network call entirely and always return the
# rule-based fallback content -- useful for offline demos.
DEMO_MODE=false

# GCS bucket holding tokyu.db, the source of truth for member data. Auth is
# via Application Default Credentials (same as Vertex AI above) -- leave
# GCS_BUCKET_NAME empty to fall back to local seed data instead.
GCS_BUCKET_NAME=tokyu
GCS_DB_OBJECT_NAME=tokyu.db
